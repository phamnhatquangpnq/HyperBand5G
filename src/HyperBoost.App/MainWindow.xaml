<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="HyperBoost.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:models="clr-namespace:HyperBoost.Core.Models;assembly=HyperBoost.Core" xmlns:converters="clr-namespace:HyperBoost.App.Converters" Title="HyperBoost 5G &amp; PC Suite - Smart Wi-Fi &amp; System Optimizer Pro" Height="760" Width="1180" MinHeight="500" MinWidth="700" Background="{DynamicResource KillerDarkBrush}" Foreground="{DynamicResource KillerTextBrush}" WindowStartupLocation="CenterScreen" xmlns:app="clr-namespace:HyperBoost.App">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <converters:ExePathToIconConverter x:Key="ExePathToIconConverter" />
      <converters:BindingProxy x:Key="LocProxy" Data="{Binding Loc}" />
      <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />
      <Style x:Key="CenteredText" TargetType="{x:Type TextBlock}">
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
      </Style>
      <Style x:Key="BoldText" TargetType="{x:Type TextBlock}">
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{DynamicResource KillerAccentBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid Row="0" Margin="0,0,0,15">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="15" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Grid Column="0" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="HYPER" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource KillerAccentBrush}" />
          <TextBlock Text="BOOST" FontSize="28" FontWeight="Light" Foreground="#FFFFFFFF" />
        </StackPanel>
        <Border Grid.Column="1" Background="#1A2333" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="15,0,0,0" Padding="8,4" VerticalAlignment="Center" HorizontalAlignment="Left">
          <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}" TextTrimming="CharacterEllipsis" Text="{Binding Loc.AppSubtitle}" />
        </Border>
      </Grid>
      <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
          <Button CommandParameter="vn" Style="{StaticResource KillerSmallButtonStyle}" Padding="8,5" Margin="0,0,6,0" Command="{Binding SwitchLanguageCommand}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="🇻🇳" FontSize="16" Margin="0,0,4,0" />
              <TextBlock Text="VN" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
          <Button CommandParameter="en" Style="{StaticResource KillerSmallButtonStyle}" Padding="8,5" Command="{Binding SwitchLanguageCommand}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="🇺🇸" FontSize="16" Margin="0,0,4,0" />
              <TextBlock Text="EN" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
        <Border Background="#121722" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="12,6" Margin="0,0,15,0">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{Binding CurrentBandBadgeColor}" />
            <TextBlock FontWeight="SemiBold" Margin="0,0,8,0" MaxWidth="140" TextTrimming="CharacterEllipsis" Text="{Binding CurrentStatus.Ssid, FallbackValue=Disconnected}" />
            <TextBlock FontWeight="Bold" Text="{Binding CurrentBandBadgeText}" Foreground="{Binding CurrentBandBadgeColor}" />
          </StackPanel>
        </Border>
        <Button Style="{StaticResource KillerButtonStyle}" Padding="15,8" Content="{Binding Loc.BtnRefresh}" Command="{Binding RefreshCommand}" />
      </StackPanel>
    </Grid>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
      <Button CommandParameter="0" Style="{StaticResource KillerButtonStyle}" Margin="0,0,10,0" Padding="18,8" FontSize="14" FontWeight="Bold" Content="{Binding Loc.DashboardTabTitle}" Command="{Binding SwitchTabCommand}" />
      <Button CommandParameter="1" Style="{StaticResource KillerButtonStyle}" Margin="0,0,10,0" Padding="18,8" FontSize="14" FontWeight="Bold" Content="{Binding Loc.OptimizerTabTitle}" Command="{Binding SwitchTabCommand}" />
      <Button CommandParameter="2" Style="{StaticResource KillerButtonStyle}" Margin="0,0,10,0" Padding="18,8" FontSize="14" FontWeight="Bold" Content="{Binding Loc.UninstallerTabTitle}" Command="{Binding SwitchTabCommand}" />
      <Button CommandParameter="3" Style="{StaticResource KillerSmallButtonStyle}" Padding="18,8" FontSize="14" FontWeight="SemiBold" Content="{Binding Loc.SettingsTabTitle}" Command="{Binding SwitchTabCommand}" />
    </StackPanel>
    <Border Grid.Row="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20,15" Margin="0,0,0,15">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
          <StackPanel Orientation="Horizontal">
            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFFFF" TextWrapping="Wrap" Text="{Binding Loc.SmartSelectionTitle}" />
            <Border Background="#00FFFFFF" BorderBrush="{DynamicResource KillerGreenBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="12,0,0,0">
              <TextBlock FontSize="10" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" Text="{Binding Loc.ActiveMonitoring}" />
            </Border>
          </StackPanel>
          <TextBlock FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" Margin="0,4,0,0" TextWrapping="Wrap" Text="{Binding Loc.SmartSelectionDesc}" />
        </StackPanel>
        <Button Grid.Column="1" Style="{StaticResource KillerToggleButtonStyle}" Padding="25,10" FontSize="14" FontWeight="Bold" Command="{Binding ToggleSmartSelectionCommand}" Content="{Binding IsSmartSelectionEnabled, Converter={StaticResource BoolToToggleTextConverter}}" Background="{Binding IsSmartSelectionEnabled, Converter={StaticResource BoolToToggleColorConverter}}" />
      </Grid>
    </Border>
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=0}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="9*" />
          <ColumnDefinition Width="15" />
          <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>
        <Grid Column="0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Grid.Row="0" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}" Text="{Binding Loc.AuthorizedNetworksTitle}" />
                <TextBlock FontSize="11" Foreground="{DynamicResource KillerMutedBrush}" VerticalAlignment="Center" Margin="8,0,0,0" Text="{Binding Loc.AuthorizedNetworksDesc}" />
              </StackPanel>
              <DataGrid Grid.Row="1" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="220" ItemsSource="{Binding AuthorizedNetworks}">
                <DataGrid.RowStyle>
                  <Style TargetType="{x:Type DataGridRow}">
                    <Setter Property="Background" Value="#00FFFFFF" />
                    <Setter Property="Foreground" Value="#FFFFFFFF" />
                    <Style.Triggers>
                      <DataTrigger Value="True" Binding="{Binding IsCurrentConnection}">
                        <Setter Property="Background" Value="#152433" />
                        <Setter Property="Foreground" Value="{DynamicResource KillerGreenBrush}" />
                        <Setter Property="FontWeight" Value="Bold" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                  <DataGridTemplateColumn Width="4*" Header="{Binding Data.ColName, Source={StaticResource LocProxy}}">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <TextBlock FontSize="13" TextTrimming="CharacterEllipsis" Text="{Binding Ssid}" />
                          <Border Background="#1A332C" BorderBrush="{DynamicResource KillerGreenBrush}" BorderThickness="1" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" Visibility="{Binding IsCurrentConnection, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock FontSize="9" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" Text="{Binding DataContext.Loc.BadgeActive, RelativeSource={RelativeSource AncestorType=Window}}" />
                          </Border>
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Width="3*" Header="{Binding Data.ColBssid, Source={StaticResource LocProxy}}" Binding="{Binding Bssid}" />
                  <DataGridTextColumn Width="1*" Header="{Binding Data.ColBand, Source={StaticResource LocProxy}}" Binding="{Binding BandDisplay}" />
                  <DataGridTemplateColumn Width="3*" Header="{Binding Data.ColSignal, Source={StaticResource LocProxy}}">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Grid Width="60" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                            <ProgressBar Maximum="100" Style="{StaticResource SegmentedSignalBarStyle}" Value="{Binding SignalQuality}" />
                          </Grid>
                          <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding SignalDisplay}" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Width="1*" Header="{Binding Data.ColScore, Source={StaticResource LocProxy}}" Binding="{Binding ScoreDisplay}" />
                  <DataGridTextColumn Width="2*" Header="{Binding Data.ColClass, Source={StaticResource LocProxy}}" Binding="{Binding PhyKindDisplay}" />
                  <DataGridTemplateColumn Width="3*" Header="{Binding Data.ColAction, Source={StaticResource LocProxy}}">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <Button Style="{StaticResource KillerSmallButtonStyle}" HorizontalAlignment="Left" Padding="10,4" Content="{Binding DataContext.Loc.BtnForceConnect, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.ConnectToBssidCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Visibility="{Binding IsCurrentConnection, Converter={StaticResource InverseBoolToVisConverter}}" />
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
          <Border Grid.Row="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <TextBlock Grid.Row="0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}" Margin="0,0,0,10" Text="{Binding Loc.AvailableNetworksTitle}" />
              <DataGrid Grid.Row="1" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="220" ItemsSource="{Binding AvailableNetworks}">
                <DataGrid.Columns>
                  <DataGridTemplateColumn Width="4*" Header="{Binding Data.ColName, Source={StaticResource LocProxy}}">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <TextBlock FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Text="{Binding Ssid}" />
                          <Border Background="#1A332C" BorderBrush="{DynamicResource KillerGreenBrush}" BorderThickness="1" CornerRadius="4" Padding="4,1" Margin="8,0,0,0" Visibility="{Binding IsCurrentConnection, Converter={StaticResource BoolToVisConverter}}">
                            <TextBlock FontSize="9" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" Text="{Binding DataContext.Loc.BadgeActive, RelativeSource={RelativeSource AncestorType=Window}}" />
                          </Border>
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Width="3*" Header="{Binding Data.ColBssid, Source={StaticResource LocProxy}}" Binding="{Binding Bssid}" />
                  <DataGridTextColumn Width="1*" Header="{Binding Data.ColBand, Source={StaticResource LocProxy}}" Binding="{Binding BandDisplay}" />
                  <DataGridTemplateColumn Width="3*" Header="{Binding Data.ColSignal, Source={StaticResource LocProxy}}">
                    <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Grid Width="60" Height="12" Margin="0,0,6,0" VerticalAlignment="Center">
                            <ProgressBar Maximum="100" Style="{StaticResource SegmentedSignalBarStyle}" Value="{Binding SignalQuality}" />
                          </Grid>
                          <TextBlock FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Text="{Binding SignalDisplay}" />
                        </StackPanel>
                      </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                  </DataGridTemplateColumn>
                  <DataGridTextColumn Width="1*" Header="{Binding Data.ColScore, Source={StaticResource LocProxy}}" Binding="{Binding ScoreDisplay}" />
                  <DataGridTextColumn Width="2*" Header="{Binding Data.ColClass, Source={StaticResource LocProxy}}" Binding="{Binding PhyKindDisplay}" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </Border>
        </Grid>
        <Border Grid.Column="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
              <TextBlock Text="🚀 " FontSize="18" />
              <TextBlock FontSize="16" FontWeight="Bold" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.SpeedTestTabTitle}" />
            </StackPanel>
            <Grid Row="1" VerticalAlignment="Center" Margin="0,10">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Grid.Row="0" Grid.Column="0" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center" Text="{Binding Loc.PingLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" Margin="0,6,0,0" HorizontalAlignment="Center" Text="{Binding SpeedTestStatus.PingMs, StringFormat={}{0} ms}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="0" Grid.Column="2" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center" Text="{Binding Loc.JitterLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#FF9900" Margin="0,6,0,0" HorizontalAlignment="Center" Text="{Binding SpeedTestStatus.JitterMs, StringFormat={}{0} ms}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.Column="0" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center" Text="{Binding Loc.DownloadLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" Margin="0,6,0,0" HorizontalAlignment="Center" Text="{Binding SpeedTestStatus.DownloadMbps, StringFormat={}{0:F1} Mbps}" />
                </StackPanel>
              </Border>
              <Border Grid.Row="2" Grid.Column="2" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <StackPanel HorizontalAlignment="Center">
                  <TextBlock FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center" Text="{Binding Loc.UploadLabel}" />
                  <TextBlock FontSize="22" FontWeight="Bold" Foreground="#A855F7" Margin="0,6,0,0" HorizontalAlignment="Center" Text="{Binding SpeedTestStatus.UploadMbps, StringFormat={}{0:F1} Mbps}" />
                </StackPanel>
              </Border>
            </Grid>
            <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="10,10,10,5">
              <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFFFF" HorizontalAlignment="Center" Margin="0,0,0,8" Text="{Binding SpeedTestStatus.CurrentStage}" />
              <ProgressBar Maximum="100" Height="14" Style="{StaticResource KillerProgressBarStyle}" Value="{Binding SpeedTestStatus.ProgressPercentage}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
              <Button Style="{StaticResource KillerButtonStyle}" Padding="25,10" FontSize="14" FontWeight="Bold" Content="{Binding Loc.BtnStartSpeedTest}" Command="{Binding StartSpeedTestCommand}" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </ScrollViewer>
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=1}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*" />
          <ColumnDefinition Width="15" />
          <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Row="0" Margin="0,0,0,12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Vertical">
                <TextBlock FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" Text="{Binding Loc.RamBoosterTitle}" />
                <TextBlock FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" Text="{Binding Loc.RamBoosterDesc}" />
              </StackPanel>
              <Button Grid.Column="1" Style="{StaticResource KillerButtonStyle}" Padding="15,8" FontSize="13" FontWeight="Bold" Content="{Binding Loc.BtnOptimizeRam}" Command="{Binding OptimizeRamCommand}" IsEnabled="{Binding IsNotOptimizingRam}" />
            </Grid>
            <Border Grid.Row="1" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
              <StackPanel>
                <Grid Margin="0,0,0,6">
                  <TextBlock Text="System Memory / RAM Sử Dụng:" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" HorizontalAlignment="Right" Text="{Binding MemoryStatus.DisplayText}" />
                </Grid>
                <ProgressBar Maximum="100" Height="14" Style="{StaticResource KillerProgressBarStyle}" Value="{Binding MemoryStatus.UsedPercentage}" />
              </StackPanel>
            </Border>
            <DataGrid Grid.Row="2" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" MaxHeight="350" ItemsSource="{Binding TopProcesses}">
              <DataGrid.Columns>
                <DataGridTemplateColumn Width="3*" Header="{Binding Data.ColProcName, Source={StaticResource LocProxy}}">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Image Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform" Source="{Binding ExecutablePath, Converter={StaticResource ExePathToIconConverter}}" />
                        <TextBlock FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding DisplayName}" />
                      </StackPanel>
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="1*" Header="{Binding Data.ColProcId, Source={StaticResource LocProxy}}" Binding="{Binding ProcessId}" />
                <DataGridTextColumn Width="2*" Header="{Binding Data.ColProcRam, Source={StaticResource LocProxy}}" Binding="{Binding WorkingSetDisplay}" />
                <DataGridTemplateColumn Width="2*" Header="{Binding Data.ColProcAction, Source={StaticResource LocProxy}}">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource KillerSmallButtonStyle}" Background="#33FF3355" BorderBrush="#FF3355" Foreground="#FF3355" Padding="8,4" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Content="{Binding DataContext.Loc.BtnEndTask, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.EndTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding ProcessId}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>
          </Grid>
        </Border>
        <Border Grid.Column="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="18">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,15">
              <TextBlock FontSize="15" FontWeight="Bold" Foreground="#38BDF8" Text="{Binding Loc.JunkCleanerTitle}" />
              <TextBlock FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" TextWrapping="Wrap" Margin="0,4,0,0" Text="{Binding Loc.JunkCleanerDesc}" />
            </StackPanel>
            <Border Grid.Row="1" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="15" VerticalAlignment="Stretch">
              <StackPanel VerticalAlignment="Center">
                <Grid Margin="0,8">
                  <TextBlock FontSize="13" Foreground="#FFFFFFFF" Text="{Binding Loc.JunkUserTempLabel}" />
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" Text="{Binding JunkResult.UserTempFiles, StringFormat={}{0} files}" />
                </Grid>
                <Grid Margin="0,8">
                  <TextBlock FontSize="13" Foreground="#FFFFFFFF" Text="{Binding Loc.JunkWinTempLabel}" />
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" Text="{Binding JunkResult.WinTempFiles, StringFormat={}{0} files}" />
                </Grid>
                <Grid Margin="0,8">
                  <TextBlock FontSize="13" Foreground="#FFFFFFFF" Text="{Binding Loc.JunkRecycleBinLabel}" />
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="#FF9900" HorizontalAlignment="Right" Text="{Binding JunkResult.RecycleBinItems, StringFormat={}{0} items}" />
                </Grid>
                <Grid Margin="0,6">
                  <TextBlock FontSize="13" Foreground="#FFFFFFFF" Text="{Binding Loc.JunkLogsLabel}" />
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" Text="{Binding JunkResult.LogFiles, StringFormat={}{0} files}" />
                </Grid>
                <Border BorderBrush="#1F2E40" BorderThickness="0,1,0,0" Margin="0,8,0,4" Padding="0,8,0,0">
                  <Grid>
                    <TextBlock Text="⚡ Ultra COMPRESS Mode:" FontSize="13" FontWeight="Bold" Foreground="#A855F7" />
                    <TextBlock Text="Ready (~2-5GB C:)" FontSize="12" FontWeight="ExtraBold" Foreground="#00F280" HorizontalAlignment="Right" />
                  </Grid>
                </Border>
                <Border Background="#121824" BorderBrush="#2A384D" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,6,0,0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" />
                      <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="⏳ LOG:" FontSize="11" FontWeight="Bold" Foreground="#FF007F" Margin="0,0,6,0" />
                    <TextBlock Grid.Column="1" Text="{Binding LiveJunkLogText}" FontSize="11" FontFamily="Consolas" Foreground="#38BDF8" TextTrimming="CharacterEllipsis" />
                  </Grid>
                </Border>
              </StackPanel>
            </Border>
            <StackPanel Grid.Row="2" Margin="0,15,0,0">
              <Border Background="#152433" BorderBrush="{DynamicResource KillerAccentBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,15">
                <Grid>
                  <TextBlock FontSize="13" FontWeight="Bold" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.TotalJunkFoundLabel}" />
                  <TextBlock FontSize="20" FontWeight="ExtraBold" Foreground="#00F280" HorizontalAlignment="Right" Text="{Binding JunkResult.TotalSizeDisplay}" />
                </Grid>
              </Border>
              <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="10" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Style="{StaticResource KillerButtonStyle}" Padding="10,12" FontSize="13" FontWeight="Bold" Content="{Binding Loc.BtnScanJunk}" Command="{Binding ScanJunkCommand}" IsEnabled="{Binding IsNotScanningJunk}" />
                <Button Grid.Column="2" Style="{StaticResource KillerButtonStyle}" Background="#FF007F" BorderBrush="#FF007F" Padding="10,12" FontSize="13" FontWeight="Bold" Content="{Binding Loc.BtnCleanJunk}" Command="{Binding CleanJunkCommand}" IsEnabled="{Binding IsNotScanningJunk}" />
              </Grid>
              <Button Style="{StaticResource KillerButtonStyle}" Background="#7928CA" BorderBrush="#A855F7" Foreground="#FFFFFFFF" Padding="10,12" FontSize="13" FontWeight="ExtraBold" Content="{Binding Loc.BtnUltraCompress}" Command="{Binding UltraCompressCommand}" IsEnabled="{Binding IsNotScanningJunk}">
                <FrameworkElement.ToolTip>
                  <ToolTip Content="Kích hoạt chế độ Ultra COMPRESS Mode (số 4) - Nén WOF CompactOS và WinSxS để tiết kiệm 2GB đến 5GB dung lượng ổ C:." />
                </FrameworkElement.ToolTip>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </ScrollViewer>
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=2}">
      <Border Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="25">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
              <TextBlock Text="🗑️ " FontSize="22" Foreground="#FF007F" />
              <StackPanel>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#FFFFFFFF" Text="{Binding Loc.UninstallerTitle}" />
                <TextBlock FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" Margin="0,4,0,0" Text="{Binding Loc.UninstallerDesc}" />
              </StackPanel>
            </StackPanel>
            <Button HorizontalAlignment="Right" VerticalAlignment="Center" Content="🔄 Quét Lại App" Style="{StaticResource KillerButtonStyle}" Padding="15,8" FontSize="13" Command="{Binding RefreshAppsCommand}" IsEnabled="{Binding IsNotLoadingApps}" />
          </Grid>
          <DataGrid Grid.Row="1" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserSortColumns="True" MaxHeight="550" ItemsSource="{Binding InstalledApps}">
            <DataGrid.Columns>
              <DataGridTemplateColumn SortMemberPath="DisplayName" Width="3*" Header="{Binding Data.ColAppName, Source={StaticResource LocProxy}}">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <Image Width="18" Height="18" Margin="0,0,8,0" Stretch="Uniform" Source="{Binding IconPath, Converter={StaticResource ExePathToIconConverter}}" />
                      <TextBlock FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Text="{Binding DisplayName}" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn SortMemberPath="DisplayVersion" Width="1.2*" Header="{Binding Data.ColAppVersion, Source={StaticResource LocProxy}}" Binding="{Binding DisplayVersion}" />
              <DataGridTextColumn SortMemberPath="Publisher" Width="2*" Header="{Binding Data.ColAppPublisher, Source={StaticResource LocProxy}}" Binding="{Binding Publisher}" />
              <DataGridTextColumn SortMemberPath="InstallDate" Width="1.2*" Header="{Binding Data.ColAppDate, Source={StaticResource LocProxy}}" Binding="{Binding InstallDate}" />
              <DataGridTextColumn SortMemberPath="EstimatedSizeKb" Width="1.2*" Header="{Binding Data.ColAppSize, Source={StaticResource LocProxy}}" Binding="{Binding SizeDisplay}" />
              <DataGridTemplateColumn Width="2.2*" Header="{Binding Data.ColAction, Source={StaticResource LocProxy}}">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <Button Style="{StaticResource KillerSmallButtonStyle}" Background="#33FF3355" BorderBrush="#FF3355" Foreground="#FF3355" Padding="8,4" Margin="0,0,5,0" FontSize="11" FontWeight="Bold" Content="{Binding DataContext.Loc.BtnUninstall, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.UninstallAppCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" IsEnabled="{Binding DataContext.IsNotUninstalling, RelativeSource={RelativeSource AncestorType=Window}}" />
                      <Button Style="{StaticResource KillerSmallButtonStyle}" Padding="6,4" Margin="0,0,5,0" FontSize="11" Content="{Binding DataContext.Loc.BtnAppInfo, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.ShowAppInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                      <Button Style="{StaticResource KillerSmallButtonStyle}" Padding="6,4" FontSize="11" Content="{Binding DataContext.Loc.BtnOpenFolder, RelativeSource={RelativeSource AncestorType=Window}}" Command="{Binding DataContext.OpenInstallLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
              <Style TargetType="{x:Type DataGridRow}">
                <Setter Property="Padding" Value="0,6" />
                <Setter Property="Background" Value="#00FFFFFF" />
                <Setter Property="Foreground" Value="{DynamicResource KillerTextBrush}" />
                <Setter Property="FrameworkElement.ContextMenu">
                  <Setter.Value>
                    <ContextMenu Background="{DynamicResource KillerPanelBrush}" Foreground="#FFFFFFFF" BorderBrush="{DynamicResource KillerBorderBrush}">
                      <MenuItem Header="🗑️ Gỡ Cài Đặt (Uninstall)" Command="{Binding DataContext.UninstallAppCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                      <MenuItem Header="ℹ️ Thông Tin Chi Tiết (Info)" Command="{Binding DataContext.ShowAppInfoCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                      <MenuItem Header="📂 Mở Thư Mục Cài Đặt (Open Location)" Command="{Binding DataContext.OpenInstallLocationCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" />
                    </ContextMenu>
                  </Setter.Value>
                </Setter>
                <Style.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2333" />
                  </Trigger>
                </Style.Triggers>
              </Style>
            </DataGrid.RowStyle>
          </DataGrid>
        </Grid>
      </Border>
    </ScrollViewer>
    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=3}">
      <Border Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="30">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
            <TextBlock Text="⚙ " FontSize="22" Foreground="{DynamicResource KillerAccentBrush}" />
            <TextBlock FontSize="20" FontWeight="Bold" Foreground="#FFFFFFFF" Text="{Binding Loc.SettingsTitle}" />
          </StackPanel>
          <StackPanel Grid.Row="1" MaxWidth="700" HorizontalAlignment="Stretch">
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.LanguageLabel}" />
              <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button CommandParameter="vn" Content="🇻🇳 Tiếng Việt (VN)" Style="{StaticResource KillerSmallButtonStyle}" Padding="15,8" Margin="0,0,10,0" Command="{Binding SwitchLanguageCommand}" />
                <Button CommandParameter="en" Content="🇺🇸 English (US)" Style="{StaticResource KillerSmallButtonStyle}" Padding="15,8" Command="{Binding SwitchLanguageCommand}" />
              </StackPanel>
            </Grid>
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.StartupLabel}" />
              <CheckBox Grid.Column="1" Content="Enabled / Bật tự khởi động" Foreground="{DynamicResource KillerGreenBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" IsChecked="{Binding RunOnStartup}" />
            </Grid>
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.PollIntervalLabel}" />
              <Slider Grid.Column="1" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center" Value="{Binding PollIntervalSeconds}" />
              <TextBlock Grid.Column="2" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding PollIntervalSeconds, StringFormat={}{0}s}" />
            </Grid>
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.ThresholdLabel}" />
              <Slider Grid.Column="1" Minimum="15" Maximum="70" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" Value="{Binding Min5GhzQualityThreshold}" />
              <TextBlock Grid.Column="2" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding Min5GhzQualityThreshold, StringFormat={}{0}%}" />
            </Grid>
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="60" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.AutoCleanRamLabel}" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox Content="Bật / Enable" Foreground="{DynamicResource KillerGreenBrush}" FontSize="14" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center" IsChecked="{Binding AutoCleanRamEnabled}" />
                <Slider Minimum="30" Maximum="300" TickFrequency="30" IsSnapToTickEnabled="True" Width="150" VerticalAlignment="Center" Value="{Binding AutoCleanRamIntervalSeconds}" />
              </StackPanel>
              <TextBlock Grid.Column="2" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding AutoCleanRamIntervalSeconds, StringFormat={}{0}s}" />
            </Grid>
            <Grid Margin="0,0,0,20">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" FontSize="15" Foreground="#FFFFFFFF" VerticalAlignment="Center" Text="{Binding Loc.ThemeLabel}" />
              <ComboBox Grid.Column="1" SelectedValuePath="Tag" Width="240" HorizontalAlignment="Left" Padding="10,8" FontSize="14" SelectedValue="{Binding SelectedTheme, Mode=TwoWay}">
                <ComboBoxItem Content="HyperDark Space (Default)" Tag="HyperDark" />
                <ComboBoxItem Content="CyberNeon Glow" Tag="CyberNeon" />
                <ComboBoxItem Content="OLED Deep Black" Tag="OLEDBlack" />
                <ComboBoxItem Content="Matrix Cyber Green" Tag="MatrixEmerald" />
                <ComboBoxItem Content="Synthwave Sunset" Tag="SunsetPulse" />
                <ComboBoxItem Content="Nordic Frost Blue" Tag="NordicFrost" />
                <ComboBoxItem Content="Royal Gold Obsidian" Tag="GoldPrestige" />
              </ComboBox>
            </Grid>
          </StackPanel>
          <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Style="{StaticResource KillerButtonStyle}" Padding="25,10" FontSize="14" Margin="0,0,15,0" Content="{Binding Loc.BtnSaveSettings}" Command="{Binding SaveSettingsCommand}" />
            <Button CommandParameter="0" Style="{StaticResource KillerSmallButtonStyle}" Padding="20,10" FontSize="14" Content="{Binding Loc.BtnClose}" Command="{Binding SwitchTabCommand}" />
          </StackPanel>
        </Grid>
      </Border>
    </ScrollViewer>
    <Border Grid.Row="4" Background="#0E121A" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,15,0,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid Row="0" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFFFF" Text="{Binding Loc.ActivityLogTitle}" />
            <TextBlock FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" VerticalAlignment="Center" Margin="10,0,0,0" Text="{Binding Loc.ActivityLogDesc}" />
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Foreground="{DynamicResource KillerMutedBrush}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" Text="{Binding Loc.LogFilterLabel}" Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVisConverter}}" />
            <ComboBox Width="135" Padding="6,3" FontSize="12" Margin="0,0,12,0" VerticalAlignment="Center" ItemsSource="{Binding LogFilters}" SelectedItem="{Binding SelectedLogFilter}" Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVisConverter}}" />
            <Button Style="{StaticResource KillerSmallButtonStyle}" Padding="12,5" FontSize="12" FontWeight="Bold" Margin="0,0,8,0" Content="{Binding Loc.BtnClearLogs}" Command="{Binding ClearLogsCommand}" Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVisConverter}}" />
            <Button Style="{StaticResource KillerSmallButtonStyle}" Padding="12,5" FontSize="12" FontWeight="Bold" Background="#1A2333" BorderBrush="#FF007F" Content="{Binding LogToggleBtnText}" Command="{Binding ToggleLogVisibilityCommand}" />
          </StackPanel>
        </Grid>
        <ListBox Grid.Row="1" Height="140" Background="#00FFFFFF" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ItemsSource="{Binding FilteredActivityLogs}" Visibility="{Binding IsLogVisible, Converter={StaticResource BoolToVisConverter}}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="135" />
                  <ColumnDefinition Width="125" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontFamily="Consolas" Foreground="{DynamicResource KillerMutedBrush}" FontSize="12" VerticalAlignment="Center" Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" />
                <Border Grid.Column="1" CornerRadius="4" Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Center" Background="{Binding BadgeBgColor}">
                  <TextBlock FontSize="11" FontWeight="Bold" Text="{Binding CategoryBadge}" Foreground="{Binding BadgeTextColor}" />
                </Border>
                <TextBlock Grid.Column="2" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center" Text="{Binding Reason}" Foreground="{Binding MessageTextColor}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>
  </Grid>
</Window>