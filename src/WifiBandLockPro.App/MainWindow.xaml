<Window x:Class="WifiBandLockPro.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:WifiBandLockPro.Core.Models;assembly=WifiBandLockPro.Core"
        mc:Ignorable="d"
        Title="HyperBand 5G - Smart Wi-Fi Steering Pro" 
        Height="780" Width="1150"
        MinHeight="650" MinWidth="900"
        Background="{DynamicResource KillerDarkBrush}"
        Foreground="{DynamicResource KillerTextBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Language Switcher -->
            <RowDefinition Height="Auto"/> <!-- Navigation Tabs -->
            <RowDefinition Height="Auto"/> <!-- Smart AP Selection Card -->
            <RowDefinition Height="*"/>    <!-- Tab Content (Dashboard / Speed Test / Settings) -->
            <RowDefinition Height="160"/>  <!-- Activity Log Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- TOP HEADER & LANGUAGE FLAG SWITCHER -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="HYPER" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource KillerAccentBrush}"/>
                <TextBlock Text="BAND 5G" FontSize="28" FontWeight="Light" Foreground="White"/>
                <Border Background="#1A2333" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="4" Margin="15,0,0,0" Padding="8,4" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Loc.AppSubtitle}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Language Flag Switcher -->
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0" VerticalAlignment="Center">
                    <Button Command="{Binding SwitchLanguageCommand}" CommandParameter="vn" Style="{StaticResource KillerSmallButtonStyle}" Padding="8,5" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🇻🇳" FontSize="16" Margin="0,0,4,0"/>
                            <TextBlock Text="VN" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SwitchLanguageCommand}" CommandParameter="en" Style="{StaticResource KillerSmallButtonStyle}" Padding="8,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🇺🇸" FontSize="16" Margin="0,0,4,0"/>
                            <TextBlock Text="EN" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Current Status Badge -->
                <Border Background="#121722" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="12,6" Margin="0,0,15,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" Fill="{Binding CurrentBandBadgeColor}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentStatus.Ssid, FallbackValue='Disconnected'}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding CurrentBandBadgeText}" Foreground="{Binding CurrentBandBadgeColor}" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Refresh Button -->
                <Button Content="{Binding Loc.BtnRefresh}" Command="{Binding RefreshCommand}" Style="{StaticResource KillerButtonStyle}" Padding="15,8"/>
            </StackPanel>
        </Grid>

        <!-- TAB NAVIGATION BAR -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <Button Content="{Binding Loc.DashboardTabTitle}" Command="{Binding SwitchTabCommand}" CommandParameter="0" 
                    Style="{StaticResource KillerButtonStyle}" Margin="0,0,10,0" Padding="18,8" FontSize="14" FontWeight="Bold"/>
            <Button Content="{Binding Loc.SpeedTestTabTitle}" Command="{Binding SwitchTabCommand}" CommandParameter="1" 
                    Style="{StaticResource KillerButtonStyle}" Margin="0,0,10,0" Padding="18,8" FontSize="14" FontWeight="Bold"/>
            <Button Content="{Binding Loc.SettingsTabTitle}" Command="{Binding SwitchTabCommand}" CommandParameter="2" 
                    Style="{StaticResource KillerSmallButtonStyle}" Padding="18,8" FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>

        <!-- SMART AP SELECTION TOGGLE CARD -->
        <Border Grid.Row="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20,15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Loc.SmartSelectionTitle}" FontSize="18" FontWeight="SemiBold" Foreground="White"/>
                        <Border Background="Transparent" BorderBrush="{DynamicResource KillerGreenBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="12,0,0,0">
                            <TextBlock Text="{Binding Loc.ActiveMonitoring}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Loc.SmartSelectionDesc}" FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Toggle Button -->
                <Button Grid.Column="1" 
                        Command="{Binding ToggleSmartSelectionCommand}"
                        Content="{Binding IsSmartSelectionEnabled, Converter={StaticResource BoolToToggleTextConverter}}"
                        Style="{StaticResource KillerToggleButtonStyle}"
                        Background="{Binding IsSmartSelectionEnabled, Converter={StaticResource BoolToToggleColorConverter}}"
                        Padding="25,10" FontSize="14" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- TAB 0: MAIN DASHBOARD (TABLES) -->
        <Grid Grid.Row="3" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=0}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/> <!-- Authorized Networks -->
                <RowDefinition Height="12"/> <!-- Spacing -->
                <RowDefinition Height="*"/> <!-- Available Networks -->
            </Grid.RowDefinitions>

            <!-- Authorized Networks (Current SSID BSSIDs) -->
            <Border Grid.Row="0" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="{Binding Loc.AuthorizedNetworksTitle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}"/>
                        <TextBlock Text="{Binding Loc.AuthorizedNetworksDesc}" FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AuthorizedNetworks}" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrentConnection}" Value="True">
                                        <Setter Property="Background" Value="#152433"/>
                                        <Setter Property="Foreground" Value="{DynamicResource KillerGreenBrush}"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="{Binding DataContext.Loc.ColName, RelativeSource={RelativeSource AncestorType=Window}}" Width="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Ssid}" FontSize="14"/>
                                            <Border Background="#1A332C" BorderBrush="{DynamicResource KillerGreenBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="10,0,0,0" Visibility="{Binding IsCurrentConnection, Converter={StaticResource BoolToVisConverter}}">
                                                <TextBlock Text="{Binding DataContext.Loc.BadgeActive, RelativeSource={RelativeSource AncestorType=Window}}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColBssid, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding Bssid}" Width="160" FontFamily="Consolas"/>
                            <DataGridTemplateColumn Header="{Binding DataContext.Loc.ColScore, RelativeSource={RelativeSource AncestorType=Window}}" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding Score}" Maximum="100" Height="14" Style="{StaticResource KillerProgressBarStyle}"/>
                                            <TextBlock Text="{Binding Score}" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColSignal, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding SignalQuality, StringFormat={}{0}%}" Width="110"/>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColBand, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding BandDisplay}" Width="110" FontWeight="Bold"/>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColClass, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding RadioType}" Width="*"/>
                            <DataGridTemplateColumn Header="{Binding DataContext.Loc.ColAction, RelativeSource={RelativeSource AncestorType=Window}}" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding DataContext.Loc.BtnForceConnect, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                Command="{Binding DataContext.ForceSwitch5GhzCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                Style="{StaticResource KillerSmallButtonStyle}" 
                                                Visibility="{Binding IsCurrentConnection, Converter={StaticResource InverseBoolToVisConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Available Networks -->
            <Border Grid.Row="2" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="{Binding Loc.AvailableNetworksTitle}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource KillerAccentBrush}" Margin="0,0,0,10"/>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AvailableNetworks}" Style="{StaticResource KillerDataGridStyle}" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColName, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding Ssid}" Width="240" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColBssid, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding Bssid}" Width="160" FontFamily="Consolas"/>
                            <DataGridTemplateColumn Header="{Binding DataContext.Loc.ColScore, RelativeSource={RelativeSource AncestorType=Window}}" Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid VerticalAlignment="Center">
                                            <ProgressBar Value="{Binding Score}" Maximum="100" Height="14" Style="{StaticResource KillerProgressBarStyle}"/>
                                            <TextBlock Text="{Binding Score}" HorizontalAlignment="Right" Margin="0,0,8,0" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColSignal, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding SignalQuality, StringFormat={}{0}%}" Width="110"/>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColBand, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding BandDisplay}" Width="110" FontWeight="Bold"/>
                            <DataGridTextColumn Header="{Binding DataContext.Loc.ColClass, RelativeSource={RelativeSource AncestorType=Window}}" Binding="{Binding RadioType}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- TAB 1: WI-FI SPEED TEST PANEL -->
        <Border Grid.Row="3" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="30" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=1}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Title -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="🚀 " FontSize="24"/>
                    <TextBlock Text="{Binding Loc.SpeedTestTabTitle}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding Loc.SpeedTestDesc}" FontSize="13" Foreground="{DynamicResource KillerMutedBrush}" VerticalAlignment="Center" Margin="15,0,0,0"/>
                </StackPanel>

                <!-- Speed Meters -->
                <Grid Grid.Row="1" Margin="0,10,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Ping -->
                    <Border Grid.Column="0" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Loc.PingLabel}" FontSize="14" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SpeedTestStatus.PingMs, StringFormat='{}{0} ms'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Jitter -->
                    <Border Grid.Column="2" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Loc.JitterLabel}" FontSize="14" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SpeedTestStatus.JitterMs, StringFormat='{}{0} ms'}" FontSize="28" FontWeight="Bold" Foreground="#FF9900" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Download -->
                    <Border Grid.Column="4" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Loc.DownloadLabel}" FontSize="14" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SpeedTestStatus.DownloadMbps, StringFormat='{}{0:F1} Mbps'}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Upload -->
                    <Border Grid.Column="6" Background="#0A0D14" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="{Binding Loc.UploadLabel}" FontSize="14" Foreground="{DynamicResource KillerMutedBrush}" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SpeedTestStatus.UploadMbps, StringFormat='{}{0:F1} Mbps'}" FontSize="28" FontWeight="Bold" Foreground="#A855F7" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Progress Bar & Status Text -->
                <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="50,0">
                    <TextBlock Text="{Binding SpeedTestStatus.CurrentStage}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <ProgressBar Value="{Binding SpeedTestStatus.ProgressPercentage}" Maximum="100" Height="20" Style="{StaticResource KillerProgressBarStyle}"/>
                </StackPanel>

                <!-- Start Speed Test Button -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <Button Content="{Binding Loc.BtnStartSpeedTest}" Command="{Binding StartSpeedTestCommand}" Style="{StaticResource KillerButtonStyle}" Padding="35,14" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- TAB 2: SETTINGS PANEL -->
        <Border Grid.Row="3" Background="{DynamicResource KillerPanelBrush}" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="30" Visibility="{Binding CurrentTabIndex, Converter={StaticResource TabIndexToVisConverter}, ConverterParameter=2}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="⚙ " FontSize="22" Foreground="{DynamicResource KillerAccentBrush}"/>
                    <TextBlock Text="{Binding Loc.SettingsTitle}" FontSize="20" FontWeight="Bold" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Width="650" HorizontalAlignment="Left">
                    <!-- Language Selection -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Loc.LanguageLabel}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Command="{Binding SwitchLanguageCommand}" CommandParameter="vn" Content="🇻🇳 Tiếng Việt (VN)" Style="{StaticResource KillerSmallButtonStyle}" Padding="15,8" Margin="0,0,10,0"/>
                            <Button Command="{Binding SwitchLanguageCommand}" CommandParameter="en" Content="🇺🇸 English (US)" Style="{StaticResource KillerSmallButtonStyle}" Padding="15,8"/>
                        </StackPanel>
                    </Grid>

                    <!-- Run on Windows Startup -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Loc.StartupLabel}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding CurrentSettings.RunOnStartup}" Content="Enabled / Bật tự khởi động" Foreground="{DynamicResource KillerGreenBrush}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Polling Interval -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Loc.PollIntervalLabel}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding CurrentSettings.PollIntervalSeconds}" Minimum="1" Maximum="10" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding CurrentSettings.PollIntervalSeconds, StringFormat='{}{0}s'}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Min 5GHz Quality Threshold -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Loc.ThresholdLabel}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1" Value="{Binding CurrentSettings.Min5GhzQualityThreshold}" Minimum="20" Maximum="70" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding CurrentSettings.Min5GhzQualityThreshold, StringFormat='{}{0}%'}" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource KillerAccentBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Theme Selection (Bound to SelectedTheme for Real-Time Switching) -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Loc.ThemeLabel}" FontSize="15" Foreground="White" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" SelectedValue="{Binding SelectedTheme, Mode=TwoWay}" SelectedValuePath="Tag" Width="240" HorizontalAlignment="Left" Padding="10,8" FontSize="14">
                            <ComboBoxItem Content="HyperDark Space (Default)" Tag="HyperDark"/>
                            <ComboBoxItem Content="CyberNeon Glow" Tag="CyberNeon"/>
                            <ComboBoxItem Content="OLED Deep Black" Tag="OLEDBlack"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="{Binding Loc.BtnSaveSettings}" Command="{Binding SaveSettingsCommand}" Style="{StaticResource KillerButtonStyle}" Padding="25,10" FontSize="14" Margin="0,0,15,0"/>
                    <Button Content="{Binding Loc.BtnClose}" Command="{Binding SwitchTabCommand}" CommandParameter="0" Style="{StaticResource KillerSmallButtonStyle}" Padding="20,10" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BOTTOM ACTIVITY LOG -->
        <Border Grid.Row="4" Background="#0E121A" BorderBrush="{DynamicResource KillerBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding Loc.ActivityLogTitle}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                    <TextBlock Text="{Binding Loc.ActivityLogDesc}" FontSize="12" Foreground="{DynamicResource KillerMutedBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <ListBox Grid.Row="1" ItemsSource="{Binding ActivityLogs}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}" FontFamily="Consolas" Foreground="{DynamicResource KillerMutedBrush}" FontSize="12"/>
                                <Border Grid.Column="1" Background="#1A2333" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding ToBand, StringFormat='-> {0}'}" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource KillerGreenBrush}"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="{Binding Reason}" Foreground="White" FontSize="12" TextWrapping="Wrap"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</Window>
